[user]
	email = peter.dobrev@gmail.com
	name = Petar Dobrev
[alias]
	gr = log --oneline --graph --decorate 
    gr1 = log --graph --decorate --pretty=oneline --abbrev-commit --all --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)'
	dcs = diff --cached --stat
	dc = diff --cached

    # Taken from https://haacked.com/archive/2014/07/28/github-flow-aliases/
    co = checkout
    ec = config --global -e
    up = !git pull --rebase --prune $@ && git submodule update --init --recursive
    cob = checkout -b
    save = !git add -A && git commit -m 'SAVEPOINT'
    wip = commit -am "WIP"
    undo = reset HEAD~1 --mixed
    amend = commit -a --amend
    wipe = !git add -A && git commit -qm 'WIPE SAVEPOINT' && git reset HEAD~1 --hard
    bclean = "!f() { \
        main=${1-$(git show-ref --verify --quiet refs/heads/main && echo main || echo master)}; \
        git checkout $main && \
        git branch --merged $main | grep -v \" $main$\" | xargs git branch -d; \
    }; f"
    bdone = "!f() { \
        main=${1-$(git show-ref --verify --quiet refs/heads/main && echo main || echo master)}; \
        git checkout $main && \
        git up && \
        git bclean $main; \
    }; f"
    bprune = "!f() { \
        main=${1-$(git show-ref --verify --quiet refs/heads/main && echo main || echo master)}; \
        git checkout -q $main && \
        git for-each-ref refs/heads/ \"--format=%(refname:short)\" | while read branch; do \
            mergeBase=$(git merge-base $main $branch) && \
            [[ $(git cherry $main $(git commit-tree $(git rev-parse \"$branch^{tree}\") -p $mergeBase -m _)) == \"-\"* ]] && \
            git branch -D $branch; \
        done; \
    }; f"

    adv = add -A -v

[core]
	excludesfile = ~/.gitignore
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[push]
	followTags = true

[safe]
	directory = /Users/pesho/.local/share/nvim/lazy/copilot.vim
